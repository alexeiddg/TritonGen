# TritonGen environment variables — NAMES ONLY, never commit real secrets.
# Copy to `.env` and adjust locally. `.env` is gitignored; this `.env.example`
# is committed as documentation.

# --- Optional MLflow experiment tracking (see shared/tracking/README.md) ---

# Gate 1: turn tracking on. Unset or "0" => every tracking call is a silent
# no-op. (Gate 2 is having the optional `mlflow` package installed, e.g.
# `pip install "tritongen[tracking]"`.)
TRITONGEN_MLFLOW=0

# Where MLflow logs. Unset => the local file store "file:./mlruns" (the default
# model: browse it with `mlflow ui`). For the deferred server model, point this
# at a running server instead, e.g.:
#   MLFLOW_TRACKING_URI=http://127.0.0.1:5000
# MLFLOW_TRACKING_URI=file:./mlruns
